# Optional: env overrides any value in kiri.toml (env wins). Handy for keeping
# secrets out of the config file. Everything here mirrors a kiri.toml key.

# Provider + model
# anthropic | openrouter | openai
# KIRI_PROVIDER=anthropic
# KIRI_MODEL=claude-opus-4-8

# Provider keys (set the one matching KIRI_PROVIDER)
ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# Discord
DISCORD_BOT_TOKEN=
# your numeric Discord user id
KIRI_OWNER_ID=

# Web tools
EXA_API_KEY=

# Voice messages (on-device STT; needs `uv sync --extra stt`)
# KIRI_STT_MODEL=base
# KIRI_STT_DEVICE=cpu
# KIRI_STT_COMPUTE_TYPE=int8
# KIRI_STT_LANGUAGE=

# Paths / tuning (optional)
# KIRI_CONFIG=/path/to/kiri.toml
# KIRI_PROMPT_FILE=/path/to/prompt.md
# KIRI_MCP_CONFIG=~/.kiri/mcp.json
